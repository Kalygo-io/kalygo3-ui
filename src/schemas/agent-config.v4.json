{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kalygo.example/schemas/agent-config-v4.schema.json",
  "title": "Agent Config v4",
  "description": "Agent configuration schema v4 - adds optional ElevenLabs voice_id for TTS/voice anthropomorphization via the ElevenLabs API.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "version",
    "data"
  ],
  "properties": {
    "schema": {
      "type": "string",
      "const": "agent_config"
    },
    "version": {
      "type": "integer",
      "const": 4
    },
    "data": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "systemPrompt"
      ],
      "properties": {
        "systemPrompt": {
          "type": "string",
          "minLength": 1,
          "description": "The system prompt that defines the agent's behavior and personality."
        },
        "model": {
          "$ref": "#/$defs/modelConfig",
          "description": "Configuration for the LLM that powers this agent. If not specified, defaults to OpenAI gpt-4o-mini."
        },
        "elevenlabsVoiceId": {
          "type": "string",
          "minLength": 1,
          "description": "Optional ElevenLabs voice ID used to anthropomorphize the agent through voice when using the ElevenLabs API for text-to-speech (e.g. in TTS Chat or Multi-Agent TTS Chat). If omitted, a default voice or browser TTS may be used."
        },
        "tools": {
          "type": "array",
          "minItems": 0,
          "description": "Array of tools available to the agent. Can be empty for simple chat agents. Each tool extends the agent's capabilities.",
          "items": {
            "$ref": "#/$defs/tool"
          },
          "default": []
        }
      }
    }
  },
  "$defs": {
    "modelConfig": {
      "type": "object",
      "description": "Configuration for the LLM provider and model.",
      "additionalProperties": false,
      "required": [
        "provider",
        "model"
      ],
      "properties": {
        "provider": {
          "type": "string",
          "enum": [
            "openai",
            "anthropic",
            "google",
            "ollama"
          ],
          "description": "The LLM provider. Each provider has different available models and may require different credentials."
        },
        "model": {
          "type": "string",
          "minLength": 1,
          "description": "The model identifier. Examples: 'gpt-4o-mini', 'gpt-4o', 'claude-3-5-sonnet-20241022', 'llama3.2'."
        }
      }
    },
    "tool": {
      "type": "object",
      "description": "A tool that the agent can use. Tool type determines available properties.",
      "required": [
        "type"
      ],
      "oneOf": [
        {
          "$ref": "#/$defs/vectorSearchTool"
        },
        {
          "$ref": "#/$defs/vectorSearchWithRerankingTool"
        },
        {
          "$ref": "#/$defs/dbTableReadTool"
        },
        {
          "$ref": "#/$defs/dbTableWriteTool"
        },
        {
          "$ref": "#/$defs/sendTxtEmailWithSesTool"
        },
        {
          "$ref": "#/$defs/sendHtmlEmailWithSesTool"
        },
        {
          "$ref": "#/$defs/sendTxtEmailWithGoogleOAuthTool"
        },
        {
          "$ref": "#/$defs/sendTxtEmailWithGoogleSmtpTool"
        }
      ]
    },
    "vectorSearchTool": {
      "type": "object",
      "description": "Vector database search tool for semantic retrieval from knowledge bases.",
      "additionalProperties": false,
      "required": [
        "type",
        "provider",
        "index",
        "namespace"
      ],
      "properties": {
        "type": {
          "type": "string",
          "const": "vectorSearch"
        },
        "provider": {
          "type": "string",
          "enum": [
            "pinecone"
          ]
        },
        "index": {
          "type": "string",
          "minLength": 1
        },
        "namespace": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "topK": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100,
          "default": 10
        }
      }
    },
    "vectorSearchWithRerankingTool": {
      "type": "object",
      "description": "Vector database search with re-ranking.",
      "additionalProperties": false,
      "required": [
        "type",
        "provider",
        "index",
        "namespace"
      ],
      "properties": {
        "type": {
          "type": "string",
          "const": "vectorSearchWithReranking"
        },
        "provider": {
          "type": "string",
          "enum": [
            "pinecone"
          ]
        },
        "index": {
          "type": "string",
          "minLength": 1
        },
        "namespace": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "topK": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100,
          "default": 20
        },
        "topN": {
          "type": "integer",
          "minimum": 1,
          "maximum": 50,
          "default": 5
        }
      }
    },
    "dbTableReadTool": {
      "type": "object",
      "description": "Database read tool.",
      "additionalProperties": false,
      "required": [
        "type",
        "credentialId",
        "table"
      ],
      "properties": {
        "type": {
          "type": "string",
          "const": "dbTableRead"
        },
        "credentialId": {
          "type": "integer",
          "minimum": 1
        },
        "table": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "columns": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        },
        "maxLimit": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1000,
          "default": 100
        }
      }
    },
    "dbTableWriteTool": {
      "type": "object",
      "description": "Database write tool.",
      "additionalProperties": false,
      "required": [
        "type",
        "credentialId",
        "table",
        "columns"
      ],
      "properties": {
        "type": {
          "type": "string",
          "const": "dbTableWrite"
        },
        "credentialId": {
          "type": "integer",
          "minimum": 1
        },
        "table": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "columns": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        },
        "requiredColumns": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": []
        },
        "injectAccountId": {
          "type": "boolean",
          "default": false
        },
        "injectChatSessionId": {
          "type": "boolean",
          "default": false
        }
      }
    },
    "sendTxtEmailWithSesTool": {
      "type": "object",
      "description": "Plain-text email sending tool via AWS SES. Sends emails using AWS credentials stored in the caller's credentials database. The agent provides the recipient, subject, and body at runtime.",
      "additionalProperties": false,
      "required": [
        "type",
        "credentialId"
      ],
      "properties": {
        "type": {
          "type": "string",
          "const": "sendTxtEmailWithSes"
        },
        "credentialId": {
          "type": "integer",
          "minimum": 1,
          "description": "ID of the stored AWS SES credential (service_name = AWS_SES). Must contain aws_access_key_id, aws_secret_access_key, aws_region, and from_email."
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "description": "Optional description shown to the LLM to guide when and how to use the tool."
        }
      }
    },
    "sendHtmlEmailWithSesTool": {
      "type": "object",
      "description": "HTML email sending tool via AWS SES. The agent writes a plain-text body; each non-empty line is wrapped in a <p> tag at send time.",
      "additionalProperties": false,
      "required": [
        "type",
        "credentialId"
      ],
      "properties": {
        "type": {
          "type": "string",
          "const": "sendHtmlEmailWithSes"
        },
        "credentialId": {
          "type": "integer",
          "minimum": 1,
          "description": "ID of the stored AWS SES credential (service_name = AWS_SES)."
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "description": "Optional description shown to the LLM to guide when and how to use the tool."
        }
      }
    },
    "sendTxtEmailWithGoogleOAuthTool": {
      "type": "object",
      "description": "Plain-text email sending tool via Google Gmail API using OAuth.",
      "additionalProperties": false,
      "required": [
        "type",
        "credentialId"
      ],
      "properties": {
        "type": {
          "type": "string",
          "const": "sendTxtEmailWithGoogleOAuth"
        },
        "credentialId": {
          "type": "integer",
          "minimum": 1,
          "description": "ID of the stored Google OAuth credential (service_name = GOOGLE_OAUTH). Must contain client_id, client_secret, refresh_token, and from_email."
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "description": "Optional description shown to the LLM to guide when and how to use the tool."
        }
      }
    },
    "sendTxtEmailWithGoogleSmtpTool": {
      "type": "object",
      "description": "Plain-text email sending tool via Gmail SMTP using an App Password.",
      "additionalProperties": false,
      "required": [
        "type",
        "credentialId"
      ],
      "properties": {
        "type": {
          "type": "string",
          "const": "sendTxtEmailWithGoogleSmtp"
        },
        "credentialId": {
          "type": "integer",
          "minimum": 1,
          "description": "ID of the stored Gmail SMTP credential (service_name = GOOGLE_GMAIL_SMTP). Must contain from_email and app_password."
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "description": "Optional description shown to the LLM to guide when and how to use the tool."
        }
      }
    }
  }
}